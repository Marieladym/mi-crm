# Auto-CRM - Variables de Entorno
# Copia este archivo como .env.local: cp .env.example .env.local

# =============================================================================
# FACEBOOK / META LEAD ADS (para recibir leads de Instant Forms automaticamente)
# =============================================================================
# META_VERIFY_TOKEN: una palabra secreta que tu inventas. La pones igual aqui
#   y en la configuracion del Webhook en Meta for Developers.
# META_ACCESS_TOKEN: token de Usuario del Sistema (System User) de Business
#   Manager. NO expira. Ver GUIA-INSTALACION.md (Parte 3).
# META_VERIFY_TOKEN=mi_token_secreto
# META_ACCESS_TOKEN=EAAxxxxx...

# =============================================================================
# OPCIONAL: API de Claude para clasificacion de leads con IA
# Si no se configura, el CRM usa scoring basado en reglas (funciona igual de bien)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPCIONAL: Email digest diario (registrate gratis en resend.com)
# =============================================================================
# RESEND_API_KEY=re_...
# DIGEST_EMAIL=tu@email.com
# DIGEST_FROM=Auto-CRM <onboarding@resend.dev>
